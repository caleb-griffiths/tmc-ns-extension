{
    "manifest_version": 3,
    "name": "Caleb's NetSuite Extension",
    "version": "1.0",
    "description": "",
    
    "icons": {
        "128": "icon.png"
    },

    "action": {
        "default_icon": {
            "128": "icon.png"
        },
        "default_title": "Caleb's NetSuite Extension",
        "default_popup": "popup.html"
    },

    "permissions": [
        "tabs",
        "scripting"
    ],

    "host_permissions": [
        "https://4635302.app.netsuite.com/*"
    ],

    "background": {
        "service_worker": "background.js"
    }
}
